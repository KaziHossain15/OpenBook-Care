ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional. Defaults to "anthropic" when ANTHROPIC_API_KEY is set, otherwise "mock".
OPENBOOK_CHAT_MODE=anthropic
# Optional. Current Anthropic alias used by the backend if not provided:
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional CORS — comma-separated extra browser origins (production custom domains).
# CORS_ALLOW_ORIGINS=https://openbook-care.example.com

# Optional CORS regex for Origin header (default allows https://*.vercel.app).
# Set to empty to disable regex matching: CORS_ALLOW_ORIGIN_REGEX=
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app
