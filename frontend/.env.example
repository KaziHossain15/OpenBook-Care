# Optional: FastAPI origin for production builds (no trailing slash).
# Leave unset locally — `vite.config.ts` proxies `/api` to localhost:8000.
# On Vercel, set this to your deployed API (Railway/Render/Fly/GCP), or omit it
# and add an `/api` → backend rewrite in `vercel.json` instead (see README).
# VITE_API_BASE_URL=https://your-service.up.railway.app
